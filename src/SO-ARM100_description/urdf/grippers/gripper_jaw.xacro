<robot xmlns:xacro="http://ros.org/wiki/xacro">
  <link name="gripper">
    <xacro:default_inertial mass="0.09"/>
    <visual><geometry><mesh filename="package://so_arm100_description/meshes/Fixed_Jaw.stl"/></geometry><material name="3d_printed"/></visual>
  </link>

  <link name="jaw">
    <xacro:default_inertial mass="0.02"/>
    <visual><geometry><mesh filename="package://so_arm100_description/meshes/Moving_Jaw.stl"/></geometry><material name="3d_printed"/></visual>
  </link>

  <joint name="gripper" type="revolute">
    <parent link="gripper"/>
    <child link="jaw"/>
    <origin xyz="-0.0202 -0.0244 0" rpy="0 3.14158 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-0.2" upper="2.0" effort="35" velocity="1"/>
  </joint>

  <xacro:macro name="insert_gripper"/>
</robot>
